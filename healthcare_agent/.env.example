# 阿里云API配置
DASHSCOPE_API_KEY=your_dashscope_api_key

# 企业微信配置
WECHAT_WORK_CORP_ID=your_corp_id
WECHAT_WORK_AGENT_ID=your_agent_id
WECHAT_WORK_SECRET=your_secret
WECHAT_WORK_TOKEN=your_token
WECHAT_WORK_ENCODING_AES_KEY=your_encoding_aes_key
WECHAT_WORK_CALLBACK_URL=https://your-domain.com/api/webhook

# 客服配置
CUSTOMER_SERVICE_USER_ID=your_customer_service_user_id

# 服务模式配置
# auto: 自动检测 (推荐)
# local: 强制使用本地模型
# api: 强制使用API服务
USE_LOCAL_MODEL=auto

# 本地模型配置
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_DEVICE=cuda  # cuda 或 cpu

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 向量库配置
CHROMA_PERSIST_DIR=data/index/chroma

# RAG配置
TOP_K=5
MAX_HISTORY=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 体检报告配置
REPORT_STORAGE_PATH=data/reports
REPORT_MAX_FILE_SIZE=10485760

# 通知服务配置
NOTIFICATION_ENABLED=true
AUTO_REMIND=true

# 会员配置
MEMBERSHIP_ENABLED=true
