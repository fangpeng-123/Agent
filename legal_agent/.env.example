# 阿里云API配置
DASHSCOPE_API_KEY=your_dashscope_api_key

# 飞书配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFY_TOKEN=your_verify_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# 服务模式配置
# auto: 自动检测 (推荐)
# local: 强制使用本地模型
# api: 强制使用API服务
USE_LOCAL_MODEL=auto

# 本地模型配置
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_DEVICE=cuda  # cuda 或 cpu

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 向量库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# RAG配置
TOP_K=5
MAX_HISTORY=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
