# MCP Server URL (SSE endpoint)
# Leave empty to use stdio transport with npx
MCP_SERVER_URL=

# MCP server command (for stdio transport)
MCP_COMMAND=npx

# MCP server arguments
MCP_ARGS=@amap/mcp-server

# API key for map service
# Can also be set via AMAP_API_KEY environment variable
API_KEY=

# Request timeout in milliseconds
TIMEOUT=30000

# Default city for searches
DEFAULT_CITY=

# Default search radius in meters
SEARCH_RADIUS=1000
